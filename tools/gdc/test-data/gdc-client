#!/usr/bin/env python3
"""Deterministic offline stand-in for gdc-client used by the Planemo fixture."""

import sys
from pathlib import Path

if len(sys.argv) < 5 or sys.argv[1] != "download":
    raise SystemExit("fixture gdc-client expects: download FILE_ID -d DEST")
file_id = sys.argv[2]
destination = Path(sys.argv[sys.argv.index("-d") + 1])
if file_id.endswith("FAIL"):
    raise SystemExit(17)
names = {"A1": "sample.vcf.gz", "A2": "sample.bam"}
output = destination / file_id
output.mkdir(parents=True, exist_ok=True)
(output / names.get(file_id, f"{file_id}.dat")).write_bytes(b"payload")

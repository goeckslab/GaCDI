<macros>
    <!-- @TOOL_VERSION@ tracks __version__ in gacdi_manifest/__init__.py, which is
         also the tag containers.yml publishes both GaCDI images under. The two
         must move together: the container requirement below resolves to that
         tag, and CI refuses to overwrite a tag that already exists on quay.
         test_version_contract.py enforces the equality. Bump the suffix alone
         only for changes confined to this wrapper. -->
    <token name="@TOOL_VERSION@">0.3.0</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">25.1</token>

    <xml name="requirements">
        <requirements>
            <container type="docker">quay.io/goeckslab/gacdi-downloader:@TOOL_VERSION@</container>
            <credentials
                name="gdc_auth"
                version="1.0"
                optional="true"
                label="GDC credentials"
                description="Used only for controlled-access GDC datasets"
            >
                <secret
                    name="gdc_token"
                    inject_as_env="GDC_AUTH_TOKEN"
                    label="Authorization token"
                    description="Acquired from the GDC portal"
                />
            </credentials>
        </requirements>
    </xml>

    <!-- Data commons file names are the only datatype signal available at
         discovery time, and their extensions are not Galaxy extensions: PDC
         publishes .mzML, .mzid and .psm where Galaxy expects mzml, mzid and
         tabular, and Thermo instrument files are .raw where Galaxy expects
         thermo.raw. Each pattern below therefore states its Galaxy datatype
         explicitly. Sniffing is avoided on purpose; these files reach hundreds
         of megabytes and several are binary or otherwise unsniffable.

         Patterns keep the complete file name as the element identifier so that
         collection elements read the same as the manifest rows they came from.
         Case is matched loosely because the commons are inconsistent about it
         (.mzML, .mzXML, .pepXML). Every pattern is anchored, and the catch-all
         excludes the extensions claimed above it, so each discovered file
         matches exactly one rule: no file is dropped, and none is claimed
         twice as a duplicate element identifier.

         sort_by must name a group the patterns actually capture. Galaxy sorts
         with operator.attrgetter(sort_by) over the match objects, and
         JsonCollectedDatasetMatch.name returns None when the pattern has no
         `name` group. Sorting two such matches raises TypeError comparing None
         to None, which surfaces only as an errored output collection: the tool
         itself has already exited 0, so its stderr is clean. These patterns
         capture `designation`, so that is what they sort on. -->
    <token name="@TYPED_EXTENSIONS@">mzml|mzid|mzxml|mgf|raw|psm|tsv|txt|maf|sf|csv|pepxml|protxml</token>

    <xml name="discover" tokens="pattern,ext">
        <discover_datasets
            pattern="(?P&lt;designation&gt;.*\.(?i:@PATTERN@))$"
            ext="@EXT@"
            directory="downloads"
            recurse="true"
            sort_by="designation"
        />
    </xml>

    <xml name="discover_typed">
        <expand macro="discover" pattern="mzml" ext="mzml"/>
        <expand macro="discover" pattern="mzid" ext="mzid"/>
        <expand macro="discover" pattern="mzxml" ext="mzxml"/>
        <expand macro="discover" pattern="mgf" ext="mgf"/>
        <expand macro="discover" pattern="raw" ext="thermo.raw"/>
        <expand macro="discover" pattern="pepxml" ext="pepxml"/>
        <expand macro="discover" pattern="protxml" ext="protxml"/>
        <expand macro="discover" pattern="psm|tsv|txt|maf|sf" ext="tabular"/>
        <expand macro="discover" pattern="csv" ext="csv"/>
        <!-- Anything the commons publish that is not named above: kept as
             untyped `data` rather than discarded, so the collection always
             accounts for every downloaded file. -->
        <discover_datasets
            pattern="(?P&lt;designation&gt;(?!.*\.(?i:@TYPED_EXTENSIONS@)$).*)$"
            ext="data"
            directory="downloads"
            recurse="true"
            sort_by="designation"
        />
    </xml>

    <xml name="citations">
        <citations>
            <citation type="bibtex"><![CDATA[
@misc{gacdi,
  title  = {GaCDI: Galaxy Cancer Data Importers},
  author = {GaCDI contributors},
  url    = {https://github.com/paulocilasjr/GaCDI}
}
            ]]></citation>
        </citations>
    </xml>
</macros>

<macros>
    <token name="@TOOL_VERSION@">0.1.0</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@PROFILE@">22.05</token>

    <!--
      The tool runs from the prebuilt Quay image, which bundles Python + the
      mcdi package (providing the `mcdi` entrypoint, e.g. `mcdi manifest gdc`).
      There is no Conda package for it, so the container is the sole runtime.
    -->
    <xml name="requirements">
        <requirements>
            <container type="docker">quay.io/goeckslab/mcdi:@TOOL_VERSION@</container>
        </requirements>
    </xml>

    <!-- Permissive text sanitizer that still blocks shell-dangerous characters. -->
    <xml name="safe_text">
        <sanitizer invalid_char="_">
            <valid initial="string.printable">
                <remove value="&apos;"/>
                <remove value="&quot;"/>
                <remove value="`"/>
                <remove value="$"/>
                <remove value="\"/>
            </valid>
        </sanitizer>
    </xml>

    <xml name="citations">
        <citations>
            <citation type="bibtex"><![CDATA[
@misc{gacdi,
  title  = {GaCDI: Galaxy Cancer Data Importers},
  author = {GaCDI contributors},
  url    = {https://github.com/goeckslab/GaCDI}
}
            ]]></citation>
        </citations>
    </xml>
</macros>
